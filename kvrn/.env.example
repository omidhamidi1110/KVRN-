# ─── KVRN ENVIRONMENT VARIABLES ──────────────────────────────────────────────
# Copy to .env.local for local development.
# NEVER commit .env.local or real secrets to git.
#
# Production secrets → set via: npx wrangler secret put KEY_NAME
# Local dev secrets  → set in .env.local only

# ─── SITE ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kvrn.com

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# dashboard.stripe.com/apikeys
# Test keys: sk_test_... / pk_test_...  |  Live keys: sk_live_... / pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# dashboard.stripe.com/webhooks → Add endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── DATABASE (NEON POSTGRES) ─────────────────────────────────────────────────
# console.neon.tech → Project → Connection string (pooled)
# IMPORTANT: Use the pooled connection string (contains "-pooler" in hostname)
DATABASE_URL=postgresql://user:password@ep-your-endpoint-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── EMAIL (RESEND) ───────────────────────────────────────────────────────────
# resend.com/api-keys
# Domain: verify kvrn.shop at resend.com/domains
# OR: use Cloudflare Email Routing to forward kvrn.shop → your inbox,
#     then configure Gmail "Send mail as" to reply from support@kvrn.shop
# See EMAIL_SETUP.md for full instructions
RESEND_API_KEY=re_your_resend_api_key_here

# ─── EMAIL ADDRESSES ──────────────────────────────────────────────────────────
# Branded support email (public-facing — never expose the Gmail address)
EMAIL_FROM=support@kvrn.shop
SUPPORT_EMAIL=support@kvrn.shop
ORDERS_EMAIL=orders@kvrn.shop
RETURNS_EMAIL=returns@kvrn.shop

# Internal forwarding destination (NEVER expose this in code or client)
# Set as a Cloudflare Worker secret, not here:
# FORWARD_TO_EMAIL=thekvrn@gmail.com

# ─── SMS (TWILIO) ─────────────────────────────────────────────────────────────
# console.twilio.com
TWILIO_ACCOUNT_SID=ACyour_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+447000000000

# ─── SHIPPING (SHIPPO) ────────────────────────────────────────────────────────
# app.goshippo.com/api
SHIPPO_API_KEY=shippo_test_your_api_key_here

# ─── ANALYTICS ────────────────────────────────────────────────────────────────
# analytics.google.com → Admin → Data Streams → Measurement ID (G-XXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Measurement Protocol secret (for server-side purchase tracking via webhook)
# analytics.google.com → Admin → Data Streams → Measurement Protocol API secrets
GA4_MEASUREMENT_PROTOCOL_SECRET=your_mp_secret_here

# clarity.microsoft.com → Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Password for /admin — change this before launch!
# Production: set via `npx wrangler secret put ADMIN_SECRET`
ADMIN_SECRET=change-this-secure-random-string-before-launch

# Admin notification email (receives low stock, dispute alerts, etc.)
ADMIN_EMAIL=hello@kvrn.com

# ─── CLOUDFLARE (set as GitHub Secrets, not here) ────────────────────────────
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ACCOUNT_ID=your_cloudflare_account_id
