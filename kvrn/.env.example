# ─── KVRN ENVIRONMENT VARIABLES ──────────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git.
# Production secrets: set in Cloudflare Pages dashboard (Settings → Environment Variables)

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Test mode keys start with sk_test_ and pk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe webhook secret — get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook signatures from Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── DATABASE (NEON POSTGRES) ─────────────────────────────────────────────────
# Get from: https://console.neon.tech
# Use the pooled connection string for serverless (Cloudflare Workers / Next.js API routes)
DATABASE_URL=postgresql://user:password@ep-your-endpoint.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── EMAIL (RESEND) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Verify your sending domain at: https://resend.com/domains
RESEND_API_KEY=re_your_resend_api_key_here

# ─── SMS (TWILIO) ─────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACyour_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+447000000000

# ─── SHIPPING (SHIPPO) ────────────────────────────────────────────────────────
# Get from: https://app.goshippo.com/api
SHIPPO_API_KEY=shippo_test_your_api_key_here

# ─── ANALYTICS ────────────────────────────────────────────────────────────────
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity project ID
# Get from: https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# ─── SITE ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kvrn.com

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Email address for admin dashboard access (magic link)
ADMIN_EMAIL=hello@kvrn.com

# ─── CLOUDFLARE (for Workers deployment) ─────────────────────────────────────
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ACCOUNT_ID=your_cloudflare_account_id
