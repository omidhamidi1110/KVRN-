{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/support/layout,_N_T_/support/faq/layout,_N_T_/support/faq/page,_N_T_/support/faq"}},"html":"<!DOCTYPE html><!--FLtkzI8NCev8ry3oxszKD--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/3ec72b587aabd33f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-74c939c87fa0092a.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-8210caca5b105758.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/909-aed3aa549e59d0fb.js\" async=\"\"></script><script src=\"/_next/static/chunks/239-0efcf3b33fe933aa.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-29dde368e443ae0d.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/support/faq/page-fe7bd80131ff4fdc.js\" async=\"\"></script><meta name=\"theme-color\" content=\"#FAFAF8\"/><title>FAQ — KVRN | KVRN</title><meta name=\"description\" content=\"Frequently asked questions about KVRN products, sizing, shipping, and returns.\"/><meta name=\"author\" content=\"KVRN\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><meta name=\"keywords\" content=\"heavyweight hoodie,400 gsm hoodie,500 gsm hoodie,oversized hoodie,quiet luxury,premium sweatpants,french terry hoodie,cropped hoodie,luxury streetwear,KVRN\"/><meta name=\"creator\" content=\"KVRN\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow\"/><meta property=\"og:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta property=\"og:description\" content=\"Double-layered hood. Concealed zipper pockets. No drawstrings. 400–500 GSM fleece.\"/><meta property=\"og:url\" content=\"https://kvrn.com\"/><meta property=\"og:site_name\" content=\"KVRN\"/><meta property=\"og:locale\" content=\"en_US\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"KVRN — Heavyweight Oversized Fleece\"/><meta name=\"twitter:description\" content=\"400–500 GSM. Quiet luxury.\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ClothingStore\",\"name\":\"KVRN\",\"url\":\"https://kvrn.com\",\"description\":\"Quiet luxury meets premium utility. Heavyweight oversized hoodies and sweatpants.\",\"email\":\"support@kvrn.shop\",\"sameAs\":[\"https://instagram.com/thekvrn\",\"https://tiktok.com/@thekvrn\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"customer support\",\"email\":\"support@kvrn.shop\",\"availableLanguage\":\"English\"}}</script><script>\n          window.dataLayer=window.dataLayer||[];\n          function gtag(){dataLayer.push(arguments);}\n          gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',functionality_storage:'granted',wait_for_update:500});\n        </script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-kvrn-bg text-kvrn-text font-body antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><a href=\"#main-content\" class=\"skip-link\">Skip to main content</a><header class=\"fixed left-0 right-0 z-[200] h-[56px] flex items-center transition-all duration-300 bg-transparent text-kvrn-text-on-dark\" style=\"top:36px\" aria-label=\"Site header\"><div class=\"container-kvrn w-full flex items-center justify-between\"><a class=\"text-[15px] font-display font-light tracking-wider uppercase hover:opacity-70 transition-opacity\" aria-label=\"KVRN — Go to homepage\" href=\"/\">KVRN</a><nav class=\"hidden lg:flex items-center gap-8\" aria-label=\"Main navigation\"><a class=\"text-[11px] font-light tracking-widest uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/shop\">Shop</a><a class=\"text-[11px] font-light tracking-widest uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/shop?type=hoodies\">Hoodies</a><a class=\"text-[11px] font-light tracking-widest uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/shop?type=sweatpants\">Sweatpants</a><a class=\"text-[11px] font-light tracking-widest uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/about\">About</a><a class=\"text-[11px] font-light tracking-widest uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/waitlist\">Waitlist</a></nav><div class=\"flex items-center gap-5\"><div class=\"hidden lg:block\"><div class=\"relative\"><button aria-label=\"Currency: USD. Click to change.\" aria-expanded=\"false\" class=\"flex items-center gap-1 text-[11px] font-light tracking-widest text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\">USD<svg width=\"8\" height=\"5\" viewBox=\"0 0 8 5\" fill=\"none\" aria-hidden=\"true\" class=\"transition-transform duration-200\"><path d=\"M1 1l3 3 3-3\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div></div><button class=\"flex items-center gap-1.5 hover:opacity-60 transition-opacity duration-150\" aria-label=\"Shopping bag, empty\"><svg width=\"18\" height=\"20\" viewBox=\"0 0 18 20\" fill=\"none\" aria-hidden=\"true\" class=\"flex-shrink-0\"><path d=\"M4 6V5a5 5 0 1110 0v1M1 8h16l-1.5 10H2.5L1 8z\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></button><button class=\"lg:hidden flex flex-col gap-[5px] p-1 -mr-1\" aria-label=\"Open navigation menu\" aria-expanded=\"false\"><span class=\"block h-px w-5 transition-colors duration-300 bg-kvrn-text-on-dark\"></span><span class=\"block h-px w-5 transition-colors duration-300 bg-kvrn-text-on-dark\"></span></button></div></div></header><div class=\"fixed inset-0 z-[300] bg-black/40 transition-opacity duration-300 lg:hidden opacity-0 pointer-events-none\" aria-hidden=\"true\"></div><div id=\"mobile-nav\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Navigation\" class=\"fixed inset-0 z-[400] bg-kvrn-bg flex flex-col px-6 pt-8 pb-10 overflow-y-auto transition-transform duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] lg:hidden -translate-x-full\"><div class=\"flex items-center justify-between mb-10\"><a class=\"text-[15px] font-display font-light tracking-wider uppercase\" href=\"/\">KVRN</a><button aria-label=\"Close menu\" class=\"p-2 -mr-2 text-kvrn-muted hover:text-kvrn-text transition-colors\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><nav class=\"flex-1\"><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:0ms;animation-fill-mode:forwards\" href=\"/shop\">Shop All</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:40ms;animation-fill-mode:forwards\" href=\"/shop?type=hoodies\">Hoodies</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:80ms;animation-fill-mode:forwards\" href=\"/shop?type=sweatpants\">Sweatpants</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:120ms;animation-fill-mode:forwards\" href=\"/about\">About</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:160ms;animation-fill-mode:forwards\" href=\"/waitlist\">Waitlist</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:200ms;animation-fill-mode:forwards\" href=\"/contact\">Contact</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:240ms;animation-fill-mode:forwards\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:280ms;animation-fill-mode:forwards\" href=\"/support/faq\">FAQ</a><a class=\"block py-4 border-b border-kvrn-border text-[26px] font-display font-light tracking-tight hover:text-kvrn-muted transition-colors duration-200 opacity-0 translate-x-[-12px]\" style=\"animation-delay:320ms;animation-fill-mode:forwards\" href=\"/support/track\">Track Order</a></nav><div class=\"mt-8 pt-6 border-t border-kvrn-border flex items-center justify-between\"><div class=\"relative\"><button aria-label=\"Currency: USD. Click to change.\" aria-expanded=\"false\" class=\"flex items-center gap-1 text-[11px] font-light tracking-widest text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\">USD<svg width=\"8\" height=\"5\" viewBox=\"0 0 8 5\" fill=\"none\" aria-hidden=\"true\" class=\"transition-transform duration-200\"><path d=\"M1 1l3 3 3-3\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex gap-5\"><a href=\"https://instagram.com/thekvrn\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"KVRN on Instagram\" class=\"text-kvrn-muted hover:text-kvrn-text transition-colors\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" stroke=\"currentColor\" stroke-width=\"1.5\"></rect><circle cx=\"12\" cy=\"12\" r=\"4\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle><circle cx=\"17.5\" cy=\"6.5\" r=\"1\" fill=\"currentColor\"></circle></svg></a><a href=\"https://tiktok.com/@thekvrn\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"KVRN on TikTok\" class=\"text-kvrn-muted hover:text-kvrn-text transition-colors\"><svg width=\"16\" height=\"18\" viewBox=\"0 0 24 27\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M19.5 3.2A5.6 5.6 0 0114 0h-3.7v18.3a2.9 2.9 0 11-2.8-3 2.9 2.9 0 011 .2V11.6a7 7 0 10.6 13.7V13.8a9.1 9.1 0 005.4 1.7V12a5.6 5.6 0 01-3.3-1.1A5.5 5.5 0 0014 12V3.7a9.3 9.3 0 005.5 1.6V1.8l-.05 1.4z\"></path></svg></a></div></div></div><div class=\"fixed inset-0 z-[300] transition-all duration-300 bg-transparent pointer-events-none\" aria-hidden=\"true\"></div><div role=\"dialog\" aria-modal=\"true\" aria-label=\"Shopping bag\" class=\"fixed top-0 right-0 bottom-0 z-[400] w-full max-w-[400px] bg-kvrn-bg flex flex-col transition-transform duration-[500ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] translate-x-full\"><div class=\"flex items-center justify-between px-6 py-5 border-b border-kvrn-border\"><h2 class=\"text-[11px] font-light tracking-widest uppercase\">Bag </h2><button aria-label=\"Close bag\" class=\"p-2 -mr-2 text-kvrn-muted hover:text-kvrn-text transition-colors\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex-1 overflow-y-auto scrollbar-thin\"><div class=\"flex flex-col items-center justify-center h-full px-6 text-center gap-5\"><p class=\"text-[13px] text-kvrn-muted\">Your bag is empty.</p><button aria-busy=\"false\" class=\"relative inline-flex items-center justify-center font-body font-light tracking-widest uppercase transition-all duration-150 ease-out select-none whitespace-nowrap -webkit-tap-highlight-color: transparent bg-transparent text-kvrn-text border border-kvrn-text hover:bg-kvrn-text hover:text-kvrn-bg active:bg-[#333333] disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none h-10 px-5 text-[11px]\"><span class=\"flex items-center gap-2\"><a href=\"/shop\">Browse products</a></span></button></div></div></div><main id=\"main-content\"><div class=\"pt-[calc(36px+56px)]\"><div class=\"container-kvrn section-padding max-w-3xl\"><nav aria-label=\"Breadcrumb\" class=\"mb-10\"><ol class=\"flex items-center gap-2 text-[11px] text-kvrn-muted tracking-wide\"><li><a class=\"hover:text-kvrn-text transition-colors\" href=\"/\">Home</a></li><li aria-hidden=\"true\">·</li><li class=\"text-kvrn-text\" aria-current=\"page\">FAQ</li></ol></nav><h1 class=\"font-display font-light text-[40px] md:text-[56px] leading-none tracking-tighter mb-16\">Questions</h1><div class=\"space-y-16\"><section aria-labelledby=\"section-Product\"><h2 id=\"section-Product\" class=\"label-11 mb-6\">Product</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-what-is-400-gsm\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What does 400 GSM mean?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-what-is-400-gsm\" role=\"region\" aria-labelledby=\"accordion-trigger-what-is-400-gsm\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-3\"><p>GSM stands for grams per square metre — the standard measurement of fabric weight. A higher number means a denser, heavier fabric.</p><p>Most hoodies on the market are 280–320 GSM. At 300 GSM, a hoodie feels light and somewhat provisional. At 400 GSM+, the fabric becomes structural — it holds its shape, drapes differently, and has a perceptible weight when you hold it.</p><p>KVRN is developed around heavyweight fleece construction. Full material specifications are listed on every product page.</p></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-why-no-drawstring\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">Why is there no drawstring?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-why-no-drawstring\" role=\"region\" aria-labelledby=\"accordion-trigger-why-no-drawstring\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>The 3-panel hood is engineered to hold its form without a drawstring. A drawstring is typically added because the hood collapses without it — the hood requires external support to maintain shape. KVRN&#x27;s hood structure eliminates that requirement. There is nothing to pull, nothing to lose, and nothing to interrupt the silhouette.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-hidden-zippers\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How do the hidden zippers work?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-hidden-zippers\" role=\"region\" aria-labelledby=\"accordion-trigger-hidden-zippers\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Each kangaroo pocket opening has a concealed YKK coil zipper running parallel behind it — one on each side. From the outside, with the zipper closed, the pockets appear completely standard. Open the zipper and you have access to a secure interior compartment. They are invisible in all positions.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-care\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How should I wash and care for the hoodie?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-care\" role=\"region\" aria-labelledby=\"accordion-trigger-care\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-3\"><p>Machine wash cold (30°C), inside out. Use a gentle cycle. Air dry — do not tumble dry. Do not iron the rubber patch.</p><p>The fleece will soften over the first 3–5 washes. This is expected behaviour — the fabric continues to improve with regular wear and care. The structure of the hood and the integrity of the zippers are not affected by washing.</p></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-fabric\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What is the fabric composition?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-fabric\" role=\"region\" aria-labelledby=\"accordion-trigger-fabric\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>100% ring-spun combed cotton. No polyester blend. Ring-spun cotton is stronger and softer than standard spun cotton due to the way the fibres are twisted. Combing removes short fibres and impurities, resulting in a cleaner, more durable yarn.</p></div></div></div></div></section><section id=\"sizing\" aria-labelledby=\"section-Sizing\"><h2 id=\"section-Sizing\" class=\"label-11 mb-6\">Sizing</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-sizing-guide\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How does KVRN fit?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-sizing-guide\" role=\"region\" aria-labelledby=\"accordion-trigger-sizing-guide\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-4\"><p>KVRN is designed to be oversized. This is not a standard fit with extra room — it is a considered oversized silhouette where the proportions are deliberate.</p><p>If you want the intended silhouette, buy your normal size. If you prefer a cleaner, more fitted oversized look, size down.</p><div class=\"overflow-x-auto mt-4\"><table class=\"w-full text-[13px]\" aria-label=\"Size guide measurements\"><thead><tr class=\"border-b border-kvrn-border\"><th class=\"text-left py-2 font-light label-11\">Size</th><th class=\"text-left py-2 font-light label-11\">Chest (cm)</th><th class=\"text-left py-2 font-light label-11\">Length (cm)</th><th class=\"text-left py-2 font-light label-11\">Sleeve (cm)</th></tr></thead><tbody class=\"divide-y divide-kvrn-border\"><tr><td class=\"py-2.5 font-light\">XS</td><td class=\"py-2.5 text-kvrn-muted\">60</td><td class=\"py-2.5 text-kvrn-muted\">72</td><td class=\"py-2.5 text-kvrn-muted\">63</td></tr><tr><td class=\"py-2.5 font-light\">S</td><td class=\"py-2.5 text-kvrn-muted\">64</td><td class=\"py-2.5 text-kvrn-muted\">74</td><td class=\"py-2.5 text-kvrn-muted\">64</td></tr><tr><td class=\"py-2.5 font-light\">M</td><td class=\"py-2.5 text-kvrn-muted\">68</td><td class=\"py-2.5 text-kvrn-muted\">76</td><td class=\"py-2.5 text-kvrn-muted\">65</td></tr><tr><td class=\"py-2.5 font-light\">L</td><td class=\"py-2.5 text-kvrn-muted\">72</td><td class=\"py-2.5 text-kvrn-muted\">78</td><td class=\"py-2.5 text-kvrn-muted\">66</td></tr><tr><td class=\"py-2.5 font-light\">XL</td><td class=\"py-2.5 text-kvrn-muted\">76</td><td class=\"py-2.5 text-kvrn-muted\">80</td><td class=\"py-2.5 text-kvrn-muted\">67</td></tr><tr><td class=\"py-2.5 font-light\">XXL</td><td class=\"py-2.5 text-kvrn-muted\">80</td><td class=\"py-2.5 text-kvrn-muted\">82</td><td class=\"py-2.5 text-kvrn-muted\">68</td></tr></tbody></table><p class=\"text-[12px] text-kvrn-muted mt-3\">All measurements in centimetres, taken flat. ±1.5cm tolerance.</p></div></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-between-sizes\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">I am between sizes — what should I do?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-between-sizes\" role=\"region\" aria-labelledby=\"accordion-trigger-between-sizes\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Size down for a cleaner oversized silhouette. The oversized cut means even a smaller size will have substantial volume. If you are unsure, email us at support@kvrn.shop with your height and usual size — we will give you a specific recommendation.</p></div></div></div></div></section><section aria-labelledby=\"section-Orders &amp; Shipping\"><h2 id=\"section-Orders &amp; Shipping\" class=\"label-11 mb-6\">Orders &amp; Shipping</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-order-time\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">When will my order ship?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-order-time\" role=\"region\" aria-labelledby=\"accordion-trigger-order-time\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Orders are typically processed within 1–2 business days. You will receive a tracking number by email once your order has shipped.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-international-duties\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">Will I pay import duties on international orders?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-international-duties\" role=\"region\" aria-labelledby=\"accordion-trigger-international-duties\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Orders shipped outside the UK may be subject to import duties and taxes levied by the destination country&#x27;s customs authority. These charges are the responsibility of the recipient and are not included in the shipping cost. For EU orders, we ship DDU (Delivered Duty Unpaid) — you will be contacted by your local customs authority if duties apply.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-order-tracking\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How do I track my order?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-order-tracking\" role=\"region\" aria-labelledby=\"accordion-trigger-order-tracking\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Once your order ships, you will receive an email with your tracking number and a direct link to track your parcel. If you have not received a shipping confirmation within 2 business days of ordering, check your spam folder or contact us at orders@kvrn.shop.</p></div></div></div></div></section><section aria-labelledby=\"section-Returns\"><h2 id=\"section-Returns\" class=\"label-11 mb-6\">Returns</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-returns-window\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What is the return window?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-returns-window\" role=\"region\" aria-labelledby=\"accordion-trigger-returns-window\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>30 days from the date of delivery, on unworn, unwashed items with tags attached. To initiate a return, email returns@kvrn.shop with your order number.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-faulty\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What if my item is faulty?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-faulty\" role=\"region\" aria-labelledby=\"accordion-trigger-faulty\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Faulty items are covered under your statutory consumer rights regardless of the 30-day window. Contact us immediately with photos of the fault at support@kvrn.shop. We will arrange a replacement or full refund — whichever you prefer.</p></div></div></div></div></section></div><div class=\"mt-20 pt-10 border-t border-kvrn-border\"><p class=\"text-[15px] font-light mb-2\">Still have a question?</p><p class=\"text-[14px] text-kvrn-muted mb-4\">Email us at<!-- --> <a href=\"mailto:support@kvrn.shop\" class=\"text-kvrn-text underline underline-offset-2 hover:opacity-70 transition-opacity\">support@kvrn.shop</a>. We respond within 24 hours.</p><a class=\"text-[13px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150 underline underline-offset-2\" href=\"/contact\">Send a message →</a></div></div></div><!--$--><!--/$--></main><footer class=\"border-t border-kvrn-border bg-kvrn-bg\" aria-label=\"Site footer\"><div class=\"container-kvrn\"><div class=\"py-12 md:py-14 grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-6\"><div class=\"col-span-2 md:col-span-1 space-y-4\"><a class=\"block text-[14px] font-display font-light tracking-wider uppercase\" href=\"/\">KVRN</a><p class=\"text-[12px] text-kvrn-muted leading-relaxed\">Quiet luxury.<br/>Premium utility.</p><div class=\"flex gap-4\"><a href=\"https://instagram.com/thekvrn\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"KVRN on Instagram (@thekvrn)\" class=\"text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" stroke=\"currentColor\" stroke-width=\"1.5\"></rect><circle cx=\"12\" cy=\"12\" r=\"4\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle><circle cx=\"17.5\" cy=\"6.5\" r=\"1\" fill=\"currentColor\"></circle></svg></a><a href=\"https://tiktok.com/@thekvrn\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"KVRN on TikTok (@thekvrn)\" class=\"text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\"><svg width=\"14\" height=\"16\" viewBox=\"0 0 24 27\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M19.5 3.2A5.6 5.6 0 0114 0h-3.7v18.3a2.9 2.9 0 11-2.8-3 2.9 2.9 0 011 .2V11.6a7 7 0 10.6 13.7V13.8a9.1 9.1 0 005.4 1.7V12a5.6 5.6 0 01-3.3-1.1A5.5 5.5 0 0014 12V3.7a9.3 9.3 0 005.5 1.6V1.8l-.05 1.4z\"></path></svg></a></div></div><div><p class=\"label-11 mb-4\">Shop</p><ul class=\"space-y-2.5\"><li><a class=\"text-[12px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\" href=\"/shop\">Shop All</a></li><li><a class=\"text-[12px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\" href=\"/shop?type=hoodies\">Hoodies</a></li><li><a class=\"text-[12px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\" href=\"/shop?type=sweatpants\">Sweatpants</a></li><li><a class=\"text-[12px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></li></ul></div><div><p class=\"label-11 mb-4\">Support</p><ul class=\"space-y-2.5\"><li><a class=\"text-[12px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150\" href=\"/support/faq\">FAQ</a