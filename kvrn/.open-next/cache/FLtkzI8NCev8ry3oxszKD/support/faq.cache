\",\"Orders & Shipping\",{\"id\":\"$undefined\",\"aria-labelledby\":\"section-Orders & Shipping\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Orders & Shipping\",\"className\":\"label-11 mb-6\",\"children\":\"Orders & Shipping\"}],[\"$\",\"$L18\",null,{\"items\":[{\"id\":\"order-time\",\"trigger\":\"When will my order ship?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Orders are typically processed within 1–2 business days. You will receive a tracking number by email once your order has shipped.\"}]},{\"id\":\"international-duties\",\"trigger\":\"Will I pay import duties on international orders?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Orders shipped outside the UK may be subject to import duties and taxes levied by the destination country's customs authority. These charges are the responsibility of the recipient and are not included in the shipping cost. For EU orders, we ship DDU (Delivered Duty Unpaid) — you will be contacted by your local customs authority if duties apply.\"}]},{\"id\":\"order-tracking\",\"trigger\":\"How do I track my order?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Once your order ships, you will receive an email with your tracking number and a direct link to track your parcel. If you have not received a shipping confirmation within 2 business days of ordering, check your spam folder or contact us at orders@kvrn.shop.\"}]}]}]]}]\n1d:[\"$\",\"section\",\"Returns\",{\"id\":\"$undefined\",\"aria-labelledby\":\"section-Returns\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Returns\",\"className\":\"label-11 mb-6\",\"children\":\"Returns\"}],[\"$\",\"$L18\",null,{\"items\":[{\"id\":\"returns-window\",\"trigger\":\"What is the return window?\",\"content\":[\"$\",\"p\",null,{\"children\":\"30 days from the date of delivery, on unworn, unwashed items with tags attached. To initiate a return, email returns@kvrn.shop with your order number.\"}]},{\"id\":\"faulty\",\"trigger\":\"What if my item is faulty?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Faulty items are covered under your statutory consumer rights regardless of the 30-day window. Contact us immediately with photos of the fault at support@kvrn.shop. We will arrange a replacement or full refund — whichever you prefer.\"}]}]}]]}]\n1e:[\"$\",\"div\",null,{\"className\":\"mt-20 pt-10 border-t border-kvrn-border\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[15px] font-light mb-2\",\"children\":\"Still have a question?\"}],[\"$\",\"p\",null,{\"className\":\"text-[14px] text-kvrn-muted mb-4\",\"children\":[\"Email us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:support@kvrn.shop\",\"className\":\"text-kvrn-text underline underline-offset-2 hover:opacity-70 transition-opacity\",\"children\":\"support@kvrn.shop\"}],\". We respond within 24 hours.\"]}],[\"$\",\"$Lb\",null,{\"href\":\"/contact\",\"className\":\"text-[13px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150 underline underline-offset-2\",\"children\":\"Send a message →\"}]]}]\n1f:[\"$\",\"$L25\",null,{\"children\":[\"$L26\",[\"$\",\"$L27\",null,{\"promise\":\"$@28\"}]]}]\n21:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#FAFAF8\"}]]\n26:null\n29:I[622,[],\"IconMark\"]\n28:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"FAQ — KVRN | KVRN\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Frequently asked questions about KVRN products, sizing, shipping, and returns.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"author\",\"content\":\"KVRN\"}],[\"$\",\"link\",\"3\",{\"rel\":\"manifest\",\"href\":\"/site.webmanifest\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"heavyweight hoodie,400 gsm hoodie,500 gsm hoodie,oversized hoodie,quiet luxury,premium sweatpants,french terry hoodie,cropped hoodie,luxury streetwear,KVRN\"}],[\