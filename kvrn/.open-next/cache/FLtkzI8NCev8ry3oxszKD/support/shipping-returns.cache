operty=\"og:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta property=\"og:description\" content=\"Double-layered hood. Concealed zipper pockets. No drawstrings. 400–500 GSM fleece.\"/><meta property=\"og:url\" content=\"https://kvrn.com\"/><meta property=\"og:site_name\" content=\"KVRN\"/><meta property=\"og:locale\" content=\"en_US\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"KVRN — Heavyweight Oversized Fleece\"/><meta name=\"twitter:description\" content=\"400–500 GSM. Quiet luxury.\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ClothingStore\",\"name\":\"KVRN\",\"url\":\"https://kvrn.com\",\"description\":\"Quiet luxury meets premium utility. Heavyweight oversized hoodies and sweatpants.\",\"email\":\"support@kvrn.shop\",\"sameAs\":[\"https://instagram.com/thekvrn\",\"https://tiktok.com/@thekvrn\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"customer support\",\"email\":\"support@kvrn.shop\",\"availableLanguage\":\"English\"}}</script><script>\n          window.dataLayer=window.dataLayer||[];\n          function gtag(){dataLayer.push(arguments);}\n          gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',functionality_storage:'granted',wait_for_update:500});\n        </script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-kvrn-bg text-kvrn-text font-body antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><a href=\"#main-content\" class=\"skip-link\">Skip to main content</a><header class=\"fixed left-0 right-0 z-[200] h-[56px] flex items-center transition-all duration-300 bg-transparent text-kvrn-text-on-dark\" style=\"top:36px\" aria-label=\"Site header\"><div class=\"c