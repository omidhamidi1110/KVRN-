-hidden=\"true\"><path d=\"M3 3L15 15M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><nav class=\"flex-1 space-y-8\" aria-label=\"Mobile navigation\"><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Shop</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/shop\">All Products</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Brand</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/about\">About KVRN</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Support</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/contact\">Contact</a></div></div></nav><div class=\"mt-8 pt-6 border-t border-[var(--color-border)] flex gap-5 flex-shrink-0\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\">Instagram</a></div></div><div class=\"fixed inset-0 z-[300] transition-all duration-300 bg-transparent pointer-events-none\" aria-hidden=\"true\"></div><div role=\"dialog\" aria-modal=\"true\" aria-label=\"Shopping bag\" class=\"fixed top-0 right-0 bottom-0 z-[400] w-full max-w-[400px] bg-[var(--color-bg)] flex flex-col transition-transform duration-[550ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] translate-x-full\"><div class=\"flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)]\"><h2 class=\"text-[11px] font-light tracking-[0.14em] uppercase\">Bag</h2><button aria-label=\"Close bag\" class=\"p-2 -mr-2 opacity-40 hover:opacity-100 transition-opacity\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex-1 overflow-y-auto scrollbar-thin\"><div class=\"flex flex-col items-center justify-center h-full px-6 text-center gap-5\"><p class=\"text-[14px] font-light text-[var(--color-muted)]\">Your bag is empty.</p><a href=\"/shop\"><button aria-busy=\"false\" class=\"relative inline-flex items-center justify-center font-body font-light tracking-widest uppercase transition-all duration-150 ease-out select-none whitespace-nowrap -webkit-tap-highlight-color: transparent bg-transparent text-kvrn-text border border-kvrn-text hover:bg-kvrn-text hover:text-kvrn-bg active:bg-[#333333] disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none h-10 px-5 text-[11px]\"><span class=\"flex items-center gap-2\">Browse collection</span></button></a></div></div></div><main id=\"main-content\"><div class=\"pt-[60px]\"><div class=\"kvrn-container section-y max-w-2xl\"><nav aria-label=\"Breadcrumb\" class=\"mb-12\"><ol class=\"flex items-center gap-2 text-[11px] font-light text-[var(--color-muted)] tracking-wide\"><li><a class=\"hover:text-[var(--color-text)] transition-colors\" href=\"/\">Home</a></li><li aria-hidden=\"true\">·</li><li class=\"text-[var(--color-text)]\" aria-current=\"page\">Privacy Policy</li></ol></nav><p class=\"kvrn-label mb-6\">Legal</p><h1 class=\"text-[clamp(36px,5vw,64px)] font-light leading-none tracking-tight mb-4\">Privacy Policy</h1><p class=\"text-[13px] font-light text-[var(--color-muted)] mb-16\">Last updated: May 2025</p><p class=\"text-[15px] font-light text-[var(--color-muted)] leading-relaxed mb-12 max-w-lg\">KVRN collects only what is necessary to operate the business. We do not sell data. We do not advertise with it.</p><div class=\"space-y-0\"><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">01<!-- -->. <!-- -->What we collect</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">When you place an order, we collect your name, email address, shipping address, and payment information. Payment data is processed and tokenised by Stripe — KVRN never stores raw card numbers. When you join our waitlist, we collect your email address and, if you opt in, your phone number. We also collect standard web analytics data (pages viewed, referral source, device type) via Google Analytics.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">02<!-- -->. <!-- -->How we use it</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Order data is used to process and fulfil your purchase, communicate about your order, and handle returns. Waitlist data is used solely to notify you of new collection releases. Analytics data is used to understand how people use the site so we can improve it. We do not sell your data to third parties. We do not use your data for advertising.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">03<!-- -->. <!-- -->Who we share it with</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Your data is shared with the services necessary to operate the business: Stripe (payments), Shippo (shipping labels), Resend (email), Twilio (SMS, if opted in), Neon (database), and Google Analytics. All providers are bound by data processing agreements. We do not share your data with any other parties.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">04<!-- -->. <!-- -->Cookies</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">We use essential cookies required for the site to function (cart state, session management) and analytics cookies (Google Analytics, Microsoft Clarity). Analytics cookies are only set after you give consent via our cookie notice. You can withdraw consent at any time via our Cookie Policy page.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">05<!-- -->. <!-- -->Your rights</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">You have the right to access the personal data we hold about you, request correction of inaccurate data, request deletion of your data, and withdraw consent for marketing communications at any time. To exercise any of these rights, email hello@kvrn.com.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">06<!-- -->. <!-- -->Retention</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Order data is retained for 7 years to comply with tax and accounting obligations. Marketing consent records are retained until you withdraw consent. Analytics data is retained for 14 months in Google Analytics.</p></div><div class=\"py-8 border-b border-[var(--color-border)] last:border-0 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-6 md:gap-12\"><p class=\"text-[13px] font-light\">07<!-- -->. <!-- -->Contact</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">For any privacy-related questions, email hello@kvrn.com. We aim to respond within 5 business days.</p></div></div><div class=\"mt-12 pt-10 border-t border-[var(--color-border)]\"><p class=\"text-[13px] font-light text-[var(--color-muted)]\">Questions?<!-- --> <a href=\"mailto:hello@kvrn.com\" class=\"text-[var(--color-text)] underline underline-offset-2 hover:opacity-70 transition-opacity\">hello@kvrn.com</a></p></div></div></div><!--$--><!--/$--></main><footer class=\"border-t border-[var(--color-border)] bg-[var(--color-bg)]\" aria-label=\"Site footer\"><div class=\"kvrn-container\"><div class=\"py-16 md:py-24 grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 md:gap-16\"><div class=\"col-span-2 md:col-span-1\"><a class=\"block text-[14px] font-light tracking-[0.2em] uppercase mb-5\" href=\"/\">KVRN</a><p class=\"text-[13px] text-[var(--color-muted)] leading-relaxed max-w-[200px]\">Designed slowly.<br/>Built to remain.</p><div class=\"flex gap-5 mt-6\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" aria-label=\"KVRN on Instagram\">Instagram</a></div></div><div><p class=\"kvrn-label mb-5\">Shop</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/shop\">All Products</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></li></ul></div><div><p class=\"kvrn-label mb-5\">Brand</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/about\">About</a></li></ul></div><div><p class=\"kvrn-label mb-5\">Support</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/track\">Track order</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a></li><li><a class=\"text-[13px] font