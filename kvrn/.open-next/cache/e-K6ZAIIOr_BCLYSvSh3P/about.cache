{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"}},"html":"<!DOCTYPE html><!--e_K6ZAIIOr_BCLYSvSh3P--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/d227774df0c1ffbf.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-74c939c87fa0092a.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-8210caca5b105758.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/909-aed3aa549e59d0fb.js\" async=\"\"></script><script src=\"/_next/static/chunks/356-1143d17a0ca27254.js\" async=\"\"></script><script src=\"/_next/static/chunks/799-3660c5de70670697.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-67a8d7c2dfb122bb.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/about/page-5161c6eec873403f.js\" async=\"\"></script><meta name=\"theme-color\" content=\"#FAFAF8\"/><title>About — KVRN | KVRN</title><meta name=\"description\" content=\"KVRN. Quiet luxury meets premium utility. The story, the standard, and the reason.\"/><meta name=\"author\" content=\"KVRN\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><meta name=\"keywords\" content=\"heavyweight hoodie,400 gsm hoodie,oversized hoodie,quiet luxury,premium hoodie,heavyweight fleece,structured hood,KVRN\"/><meta name=\"creator\" content=\"KVRN\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow\"/><meta property=\"og:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta property=\"og:description\" content=\"400 GSM+ heavyweight fleece. Structured 3-panel hood. Concealed interior zippers.\"/><meta property=\"og:url\" content=\"https://kvrn.com\"/><meta property=\"og:site_name\" content=\"KVRN\"/><meta property=\"og:locale\" content=\"en_GB\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta name=\"twitter:description\" content=\"400 GSM+ heavyweight fleece. Quiet luxury.\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ClothingStore\",\"name\":\"KVRN\",\"url\":\"https://kvrn.com\",\"description\":\"Quiet luxury meets premium utility. Heavyweight oversized hoodies and sweatpants.\",\"sameAs\":[\"https://instagram.com/kvrn\",\"https://tiktok.com/@kvrn\"]}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-kvrn-bg text-kvrn-text font-body antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><a href=\"#main-content\" class=\"skip-link\">Skip to main content</a><script>\n          window.dataLayer=window.dataLayer||[];\n          function gtag(){dataLayer.push(arguments);}\n          gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',functionality_storage:'granted',wait_for_update:500});\n        </script><header class=\"fixed top-0 left-0 right-0 z-[200] h-[56px] flex items-center transition-all duration-300 bg-[var(--color-bg)] text-[var(--color-text)]\" aria-label=\"Site header\"><div class=\"kvrn-container w-full flex items-center justify-between\"><a class=\"text-[13px] font-light tracking-[0.2em] uppercase hover:opacity-60 transition-opacity duration-150\" aria-label=\"KVRN — go to homepage\" href=\"/\">KVRN</a><nav class=\"hidden md:flex items-center gap-10\" aria-label=\"Primary navigation\"><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/shop\">Shop</a><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/about\">About</a><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/waitlist\">Waitlist</a></nav><div class=\"flex items-center gap-6\"><button class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" aria-label=\"Shopping bag\">Bag</button><button class=\"md:hidden flex flex-col gap-[5px] p-1 -mr-1\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-nav\"><span class=\"block h-px w-[22px] transition-colors duration-300\" style=\"background-color:var(--color-text)\"></span><span class=\"block h-px w-[22px] transition-colors duration-300\" style=\"background-color:var(--color-text)\"></span></button></div></div></header><div class=\"fixed inset-0 z-[300] bg-black/40 transition-opacity duration-300 md:hidden opacity-0 pointer-events-none\" aria-hidden=\"true\"></div><div id=\"mobile-nav\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Navigation menu\" class=\"fixed inset-y-0 left-0 z-[400] w-[min(340px,100vw)] bg-[var(--color-bg)] flex flex-col px-6 pt-7 pb-10 overflow-y-auto transition-transform duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] md:hidden -translate-x-full\"><div class=\"flex items-center justify-between mb-10 flex-shrink-0\"><a class=\"text-[13px] font-light tracking-[0.2em] uppercase\" href=\"/\">KVRN</a><button class=\"p-2 -mr-2 text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\" aria-label=\"Close menu\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3L15 15M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><nav class=\"flex-1 space-y-8\" aria-label=\"Mobile navigation\"><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Shop</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/shop\">All Products</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Brand</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/about\">About KVRN</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Support</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/contact\">Contact</a></div></div></nav><div class=\"mt-8 pt-6 border-t border-[var(--color-border)] flex gap-5 flex-shrink-0\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\">Instagram</a></div></div><div class=\"fixed inset-0 z-[300] transition-all duration-300 bg-transparent pointer-events-none\" aria-hidden=\"true\"></div><div role=\"dialog\" aria-modal=\"true\" aria-label=\"Shopping bag\" class=\"fixed top-0 right-0 bottom-0 z-[400] w-full max-w-[400px] bg-[var(--color-bg)] flex flex-col transition-transform duration-[550ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] translate-x-full\"><div class=\"flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)]\"><h2 class=\"text-[11px] font-light tracking-[0.14em] uppercase\">Bag</h2><button aria-label=\"Close bag\" class=\"p-2 -mr-2 opacity-40 hover:opacity-100 transition-opacity\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex-1 overflow-y-auto scrollbar-thin\"><div class=\"flex flex-col items-center justify-center h-full px-6 text-center gap-5\"><p class=\"text-[14px] font-light text-[var(--color-muted)]\">Your bag is empty.</p><a href=\"/shop\"><button aria-busy=\"false\" class=\"relative inline-flex items-center justify-center font-body font-light tracking-widest uppercase transition-all duration-150 ease-out select-none whitespace-nowrap -webkit-tap-highlight-color: transparent bg-transparent text-kvrn-text border border-kvrn-text hover:bg-kvrn-text hover:text-kvrn-bg active:bg-[#333333] disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none h-10 px-5 text-[11px]\"><span class=\"flex items-center gap-2\">Browse collection</span></button></a></div></div></div><main id=\"main-content\"><div class=\"pt-[60px]\"><section class=\"section-y bg-[var(--color-bg-dark)] text-[var(--color-text-on-dark)]\" aria-labelledby=\"about-hero\"><div class=\"kvrn-container max-w-4xl\"><p class=\"kvrn-label text-[var(--color-text-on-dark)]/40 mb-12\">KVRN</p><h1 id=\"about-hero\" class=\"text-[clamp(44px,7vw,96px)] font-light leading-[0.92] tracking-[-0.03em] mb-16\">Silence.<br/>Weight.<br/>Presence.</h1><p class=\"text-[17px] md:text-[20px] font-light text-[var(--color-text-on-dark)]/60 leading-relaxed max-w-[520px]\">KVRN exists because most clothing that calls itself premium is not. The GSM number is overstated. The construction is compromised. The branding does the work the fabric cannot.</p></div></section><section class=\"section-y border-b border-[var(--color-border)]\" aria-labelledby=\"problem-heading\"><div class=\"kvrn-container\"><div class=\"grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-16\"><div><p class=\"kvrn-label mb-4\" id=\"problem-heading\">The problem</p></div><div class=\"space-y-6 text-[16px] font-light text-[var(--color-muted)] leading-relaxed max-w-[600px]\"><p>300 GSM is sold as heavyweight. 320 GSM is called premium. 350 GSM ships with a campaign photo and a story about craftsmanship. The word is inflated. The fabric is ordinary.</p><p>A single-panel hood collapses without a drawstring — so a drawstring is added, and the silhouette becomes provisional. A chest logo is applied because the garment cannot communicate quality on its own.</p><p>We declined to make any of these compromises.</p></div></div></div></section><section class=\"section-y border-b border-[var(--color-border)]\" aria-labelledby=\"standard-heading\"><div class=\"kvrn-container\"><p class=\"kvrn-label mb-12 md:mb-16\" id=\"standard-heading\">The standard</p><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-[var(--color-border)]\"><div class=\"bg-[var(--color-bg)] px-8 py-10 md:py-12\"><p class=\"text-[15px] font-light mb-4\">The weight.</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Developed around heavyweight loopback terry. Dense enough to have real structural presence. Full specifications on each product page.</p></div><div class=\"bg-[var(--color-bg)] px-8 py-10 md:py-12\"><p class=\"text-[15px] font-light mb-4\">The hood.</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Three panels. Seamed to form a dome. No drawstring required. No drawstring installed. The structure is the solution.</p></div><div class=\"bg-[var(--color-bg)] px-8 py-10 md:py-12\"><p class=\"text-[15px] font-light mb-4\">The utility.</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Interior zipper compartments behind both kangaroo pocket openings. Invisible from outside. Functional in every position.</p></div><div class=\"bg-[var(--color-bg)] px-8 py-10 md:py-12\"><p class=\"text-[15px] font-light mb-4\">The mark.</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">One moulded rubber patch on the hood exterior. No chest logo. No sleeve hit. No hang tag with a manifesto. The garment first.</p></div></div></div></section><section class=\"section-y border-b border-[var(--color-border)] bg-[var(--color-bg-raised)]\" aria-labelledby=\"materials-heading\"><div class=\"kvrn-container\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32 items-start\"><div><p class=\"kvrn-label mb-6\" id=\"materials-heading\">Materials</p><h2 class=\"text-[clamp(28px,3.5vw,48px)] font-light leading-none tracking-tight mb-8\">100% ring-spun<br/>combed cotton.<br/>Nothing else.</h2><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed max-w-[380px]\">Ring-spun yarn is stronger and softer than standard spun cotton — the fibres are continuously twisted and thinned during processing. Combing removes short fibres and impurities. The result is a denser, more durable, cleaner yarn.</p><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed mt-4 max-w-[380px]\">No polyester. No blends added to reduce cost or improve marketing copy.</p></div><div class=\"space-y-0\"><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Fibre</span><span class=\"text-[14px] font-light text-right\">100% ring-spun combed cotton</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Weight</span><span class=\"text-[14px] font-light text-right\">400 GSM+ heavyweight fleece</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Construction</span><span class=\"text-[14px] font-light text-right\">Loopback terry, triple-brushed interior</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Face</span><span class=\"text-[14px] font-light text-right\">Dense, cold-resist smooth</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Interior</span><span class=\"text-[14px] font-light text-right\">Triple-brushed for immediate warmth</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Shrinkage</span><span class=\"text-[14px] font-light text-right\">Pre-shrunk to less than 3%</span></div><div class=\"flex items-baseline justify-between gap-8 py-4 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)]\">Care</span><span class=\"text-[14px] font-light text-right\">Machine wash cold. Air dry.</span></div></div></div></div></section><section class=\"section-y border-b border-[var(--color-border)]\" aria-labelledby=\"design-heading\"><div class=\"kvrn-container max-w-3xl\"><p class=\"kvrn-label mb-12\" id=\"design-heading\">Design logic</p><div class=\"space-y-12\"><div class=\"grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-6 md:gap-12 pb-12 border-b border-[var(--color-border)] last:border-0 last:pb-0\"><p class=\"text-[15px] font-light\">Why no drawstring?</p><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed\">A drawstring exists because the hood structure is insufficient to maintain its form independently. We built a hood structure — three separate panels seamed to create a self-supporting dome — that does not require external support. The drawstring is therefore unnecessary. Its absence is a consequence of solving the problem correctly.</p></div><div class=\"grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-6 md:gap-12 pb-12 border-b border-[var(--color-border)] last:border-0 last:pb-0\"><p class=\"text-[15px] font-light\">Why interior zippers?</p><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed\">A standard kangaroo pocket holds items that move freely and can fall. An interior zipper pocket holds items that stay. The zipper runs parallel to the pocket opening — invisible from outside, accessible from inside. Both sides. It costs more to produce. It is worth it.</p></div><div class=\"grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-6 md:gap-12 pb-12 border-b border-[var(--color-border)] last:border-0 last:pb-0\"><p class=\"text-[15px] font-light\">Why no visible branding?</p><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed\">Visible branding on a garment performs a function: it communicates that the person wearing it values the label more than the object. KVRN is designed for the opposite — for the person who wants the best version of the thing, not the loudest version of the name. One rubber patch on the hood. Nothing else needs to be said.</p></div><div class=\"grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-6 md:gap-12 pb-12 border-b border-[var(--color-border)] last:border-0 last:pb-0\"><p class=\"text-[15px] font-light\">Why 400 GSM when 300 is sufficient?</p><p class=\"text-[14px] font-light text-[var(--color-muted)] leading-relaxed\">At 300 GSM, a hoodie is functional. At 400 GSM+, it becomes structural — it holds its shape, drapes rather than hangs, and maintains its weight and presence after years of wear. The difference is perceptible immediately. There is no argument for the lesser weight.</p></div></div></div></section><section class=\"section-y border-b border-[var(--color-border)] bg-[var(--color-bg-dark)] text-[var(--color-text-on-dark)]\" aria-labelledby=\"position-heading\"><div class=\"kvrn-container\"><p class=\"kvrn-label text-[var(--color-text-on-dark)]/40 mb-12\" id=\"position-heading\">The position</p><div class=\"grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-32 max-w-3xl\"><div><p class=\"kvrn-label text-[var(--color-text-on-dark)]/60 mb-6\">KVRN is</p><ul class=\"space-y-0\"><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Architectural</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Heavyweight</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Minimal</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Functional</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Permanent</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Daily</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Considered</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)] last:border-0\">Understated</li></ul></div><div><p class=\"kvrn-label text-[var(--color-text-on-dark)]/30 mb-6\">KVRN is not</p><ul class=\"space-y-0\"><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Fast fashion</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Streetwear</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Athleisure</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Hype-driven</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Seasonal</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Promotional</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Loud</li><li class=\"py-3 border-b border-[var(--color-text-on-dark)]/10 text-[16px] font-light text-[var(--color-text-on-dark)]/30 last:border-0\">Trend-referencing</li></ul></div></div></div></section><section class=\"section-y\" aria-labelledby=\"cta-heading\"><div class=\"kvrn-container text-center\"><h2 id=\"cta-heading\" class=\"text-[clamp(32px,5vw,64px)] font-light leading-none tracking-tight mb-8\">The collection<br/>is available now.</h2><a class=\"inline-flex items-center h-12 px-10 border border-[var(--color-text)] text-[11px] font-light tracking-[0.14em] uppercase hover:bg-[var(--color-text)] hover:text-[var(--color-bg)] transition-all duration-200\" href=\"/shop\">Shop the collection</a></div></section></div><!--$--><!--/$--></main><footer class=\"border-t border-[var(--color-border)] bg-[var(--color-bg)]\" aria-label=\"Site footer\"><div class=\"kvrn-container\"><div class=\"py-16 md:py-24 grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 md:gap-16\"><div class=\"col-span-2 md:col-span-1\"><a class=\"block text-[14px] font-light tracking-[0.2em] uppercase mb-5\" href=\"/\">KVRN</a><p class=\"text-[13px] text-[var(--color-muted)] leading-relaxed max-w-[200px]\">Designed slowly.<br/>Built to remain.</p><div class=\"flex gap-5 mt-6\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" aria-label=\"KVRN on Instagram\">Instagram</a></div></div><div><p class=\"kvrn-label mb-5\">Shop</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/shop\">All Products</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors durati