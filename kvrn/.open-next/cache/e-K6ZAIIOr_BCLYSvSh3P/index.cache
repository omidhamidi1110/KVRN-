div></div></header><div class=\"fixed inset-0 z-[300] bg-black/40 transition-opacity duration-300 md:hidden opacity-0 pointer-events-none\" aria-hidden=\"true\"></div><div id=\"mobile-nav\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Navigation menu\" class=\"fixed inset-y-0 left-0 z-[400] w-[min(340px,100vw)] bg-[var(--color-bg)] flex flex-col px-6 pt-7 pb-10 overflow-y-auto transition-transform duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] md:hidden -translate-x-full\"><div class=\"flex items-center justify-between mb-10 flex-shrink-0\"><a class=\"text-[13px] font-light tracking-[0.2em] uppercase\" href=\"/\">KVRN</a><button class=\"p-2 -mr-2 text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\" aria-label=\"Close menu\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3L15 15M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><nav class=\"flex-1 space-y-8\" aria-label=\"Mobile navigation\"><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Shop</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/shop\">All Products</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Brand</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/about\">About KVRN</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Support</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/contact\">Contact</a></div></div></nav><div class=\"mt-8 pt-6 border-t border-[var(--color-border)] flex gap-5 flex-shrink-0\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\">Instagram</a></div></div><div class=\"fixed inset-0 z-[300] transition-all duration-300 bg-transparent pointer-events-none\" aria-hidden=\"true\"></div><div role=\"dialog\" aria-modal=\"true\" aria-label=\"Shopping bag\" class=\"fixed top-0 right-0 bottom-0 z-[400] w-full max-w-[400px] bg-[var(--color-bg)] flex flex-col transition-transform duration-[550ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] translate-x-full\"><div class=\"flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)]\"><h2 class=\"text-[11px] font-light tracking-[0.14em] uppercase\">Bag</h2><button aria-label=\"Close bag\" class=\"p-2 -mr-2 opacity-40 hover:opacity-100 transition-opacity\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex-1 overflow-y-auto scrollbar-thin\"><div class=\"flex flex-col items-center justify-center h-full px-6 text-center gap-5\"><p class=\"text-[14px] font-light text-[var(--color-muted)]\">Your bag is empty.</p><a href=\"/shop\"><button aria-busy=\"false\" class=\"relative inline-flex items-center justify-center font-body font-light tracking-widest uppercase transition-all duration-150 ease-out select-none whitespace-nowrap -webkit-tap-highlight-color: transparent bg-transparent text-kvrn-text border border-kvrn-text hover:bg-kvrn-text hover:text-kvrn-bg active:bg-[#333333] disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none h-10 px-5 text-[11px]\"><span class=\"flex items-center gap-2\">Browse collection</span></button></a></div></div></div><main id=\"main-content\"><section class=\"relative w-full h-[100svh] overflow-hidden bg-[var(--color-bg-dark)] flex flex-col\" aria-label=\"KVRN brand hero\"><div class=\"absolute inset-0\" style=\"background:linear-gradient(160deg, #0E0E0E 0%, #1C1917 40%, #14120F 100%)\" aria-hidden=\"true\"></div><div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image:repeating-linear-gradient(\n              0deg, transparent, transparent 1px,\n              rgba(255,255,255,0.4) 1px, rgba(255,255,255,0.4) 2px\n            );background-size:100% 3px\" aria-hidden=\"true\"></div><div class=\"relative flex-1 flex flex-col justify-end kvrn-container pb-14 md:pb-20\"><div class=\"max-w-xl\"><p class=\"kvrn-label text-[var(--color-text-on-dark)]/40 mb-6\">KVRN</p><h1 class=\"font-light text-[clamp(44px,7vw,96px)] leading-[0.95] tracking-[-0.03em] text-[var(--color-text-on-dark)] mb-8\" style=\"font-family:var(--font-display)\">Designed slowly.<br/>Built to remain.</h1><div class=\"flex flex-col sm:flex-row gap-4 items-start\"><a class=\"inline-flex items-center h-12 px-8 border border-[var(--color-text-on-dark)]/60 text-[11px] font-light tracking-[0.14em] uppercase text-[var(--color-text-on-dark)] hover:bg-[var(--color-text-on-dark)] hover:text-[var(--color-bg-dark)] transition-all duration-200\" href=\"/shop\">Shop Now</a><a class=\"inline-flex items-center h-12 px-2 text-[11px] font-light tracking-[0.14em] uppercase text-[var(--color-text-on-dark)]/50 hover:text-[var(--color-text-on-dark)] transition-colors duration-200\" href=\"/about\">About KVRN →</a></div></div></div><div class=\"relative kvrn-container pb-8 hidden md:flex items-center gap-3\" aria-hidden=\"true\"><span class=\"block w-8 h-px bg-[var(--color-text-on-dark)]/20\"></span><span class=\"text-[10px] font-light tracking-[0.2em] uppercase text-[var(--color-text-on-dark)]/30\">Scroll</span></div></section><section class=\"section-y border-b border-[var(--color-border)]\" aria-labelledby=\"philosophy-heading\"><div class=\"kvrn-container\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32 items-start\"><div><p class=\"kvrn-label mb-8\" id=\"philosophy-heading\">The Approach</p><h2 class=\"text-[clamp(32px,4vw,56px)] font-light leading-[1.0] tracking-[-0.025em] mb-8\">Built once.<br/>Worn without thought.</h2><p class=\"text-[15px] font-light text-[var(--color-muted)] leading-relaxed max-w-[400px]\">Most garments are designed to be noticed. KVRN is designed to disappear into a life — present enough to matter, considered enough to never demand attention.</p></div><div class=\"space-y-0\"><div class=\"flex gap-8 py-7 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)] pt-0.5 flex-shrink-0 w-6\">01</span><div><p class=\"text-[14px] font-light mb-2\">Intentional Design</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Every detail exists for a reason. Proportions are deliberate. Construction decisions are made for longevity, not trend.</p></div></div><div class=\"flex gap-8 py-7 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)] pt-0.5 flex-shrink-0 w-6\">02</span><div><p class=\"text-[14px] font-light mb-2\">Heavyweight Construction</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Developed around fabrics with real weight and structure. Garments that hold their form, season after season.</p></div></div><div class=\"flex gap-8 py-7 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)] pt-0.5 flex-shrink-0 w-6\">03</span><div><p class=\"text-[14px] font-light mb-2\">Considered Silhouette</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Oversized without being shapeless. Structured without being rigid. A silhouette designed to improve with wear.</p></div></div><div class=\"flex gap-8 py-7 border-b border-[var(--color-border)] last:border-0\"><span class=\"kvrn-label text-[var(--color-muted)] pt-0.5 flex-shrink-0 w-6\">04</span><div><p class=\"text-[14px] font-light mb-2\">Slower Releases</p><p class=\"text-[13px] font-light text-[var(--color-muted)] leading-relaxed\">Collections take time. KVRN releases when the work is ready — not on a calendar.</p></div></div></div></div></div></section><section class=\"section-y\" aria-labelledby=\"collection-heading\"><div class=\"kvrn-container\"><div class=\"flex items-end justify-between mb-12 md:mb-16\"><div><p class=\"kvrn-label mb-3\" id=\"collection-heading\">Drop 001</p><h2 class=\"text-[clamp(28px,3.5vw,48px)] font-light leading-none tracking-tight\">Heavyweight Collection</h2></div><a class=\"hidden md:inline-flex text-[11px] font-light tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/shop\">Shop collection →</a></div><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-10\"><a class=\"group block card-hover\" aria-label=\"Heavyweight Hoodie — $290\" href=\"/products/kvrn-heavyweight-hoodie\"><div class=\"relative aspect-[3/4] bg-[var(--color-bg-raised)] overflow-hidden mb-4\"><img alt=\"KVRN Heavyweight Hoodie in Stone — front view, structured hood down\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover img-primary\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 640px\" srcSet=\"/_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=384&amp;q=88 384w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=640&amp;q=88 640w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=750&amp;q=88 750w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=828&amp;q=88 828w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=1080&amp;q=88 1080w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=1200&amp;q=88 1200w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=1920&amp;q=88 1920w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=2048&amp;q=88 2048w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=3840&amp;q=88 3840w\" src=\"/_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-01.jpg&amp;w=3840&amp;q=88\"/><img alt=\"KVRN Heavyweight Hoodie in Stone — back view, three-panel hood visible\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover img-secondary\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 640px\" srcSet=\"/_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-02.jpg&amp;w=384&amp;q=88 384w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-02.jpg&amp;w=640&amp;q=88 640w, /_next/image?url=%2Fimages%2Fproducts%2Fhoodie-stone-02.jpg&amp;w=7