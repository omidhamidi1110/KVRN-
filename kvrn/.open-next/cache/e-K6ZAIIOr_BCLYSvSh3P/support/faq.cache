\",\\\"section\\\",\\\"Product\\\",{\\\"id\\\":\\\"$undefined\\\",\\\"aria-labelledby\\\":\\\"section-Product\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"section-Product\\\",\\\"className\\\":\\\"label-11 mb-6\\\",\\\"children\\\":\\\"Product\\\"}],[\\\"$\\\",\\\"$L14\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"what-is-400-gsm\\\",\\\"trigger\\\":\\\"What does 400 GSM mean?\\\",\\\"content\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"GSM stands for grams per square metre — the standard measurement of fabric weight. A higher number means a denser, heavier fabric.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Most hoodies on the market are 280–320 GSM. At 300 GSM, a hoodie feels light and somewhat provisional. At 400 GSM+, the fabric becomes structural — it holds its shape, drapes differently, and has a perceptible weight when you hold it.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"KVRN is developed around heavyweight fleece construction. Full material specifications are listed on every product page.\\\"}]]}]},{\\\"id\\\":\\\"why-no-drawstring\\\",\\\"trigger\\\":\\\"Why is there no drawstring?\\\",\\\"content\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"The 3-panel hood is engineered to hold its form without a drawstring. A drawstring is typically added because the hood collapses without it — the hood requires external support to maintain shape. KVRN's hood structure eliminates that requirement. There is nothing to pull, nothing to lose, and nothing to interrupt the silhouette.\\\"}]},{\\\"id\\\":\\\"hidden-zippers\\\",\\\"trigger\\\":\\\"How do the hidden zippers work?\\\",\\\"content\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Each kangaroo pocket opening has a concealed YKK coil zipper running parallel behind it — one on each side. From the outside, with the zipper closed, the pockets appear completely standard. Open the zipper and you have access to a secure interior compartment. They are invisible in all positions.\\\"}]},{\\\"id\\\":\\\"care\\\",\\\"trigger\\\":\\\"How should I wash and care for the hoodie?\\\",\\\"content\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Machine wash cold (30°C), inside out. Use a gentle cycle. Air dry — do not tumble dry. Do not iron the rubber patch.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"The fleece will soften over the first 3–5 washes. This is expected behaviour — the fabric continues to improve with regular wear and care. The structure of the hood and the integrity of the zippers are not affected by washing.\\\"}]]}]},{\\\"id\\\":\\\"fabric\\\",\\\"trigger\\\":\\\"What is the fabric composition?\\\",\\\"content\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"100% ring-spun combed cotton. No polyester blend. Ring-spun cotton is stronger and softer than standard spun cotton due to the way the fibres are twisted. Combing removes short fibres and impurities, resulting in a cleaner, more durable yarn.\\\"}]}]}]]}],[\\\"$\\\",\\\"section\\\",\\\"Sizing\\\",{\\\"id\\\":\\\"sizing\\\",\\\"aria-labelledby\\\":\\\"section-Sizing\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"section-Sizing\\\",\\\"className\\\":\\\"label-11 mb-6\\\",\\\"children\\\":\\\"Sizing\\\"}],[\\\"$\\\",\\\"$L14\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"sizing-guide\\\",\\\"trigger\\\":\\\"How does KVRN fit?\\\",\\\"content\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"KVRN is designed to be oversized. This is not a standard fit with extra room — it is a considered oversized silhouette where the proportions are deliberate.\\\"}],\\\"$L15\\\",\\\"$L16\\\"]}]},{\\\"id\\\":\\\"between-sizes\\\",\\\"trigger\\\":\\\"I am between sizes — what should I do?\\\",\\\"content\\\":\\\"$L17\\\"}]}]]}],\\\"$L18\\\",\\\"$L19\\\"]}],\\\"$L1a\\\"]}]}],null,\\\"$L1b\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"12:[\\\"$\\\",\\\"$1\\\",\\\"h\\\",{\\\"children\\\":[null,[[\\\"$\\\",\\\"$L1c\\\",null,{\\\"children\\\":\\\"$L1d\\\"}],null],[\\\"$\\\",\\\"$L1e\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"$1f\\\",null,{\\\"fallback\\\":null,\\\"children\\\":\\\"$L20\\\"}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"21:I[4431,[],\\\"OutletBoundary\\\"]\\n23:I[5278,[],\\\"AsyncMetadataOutlet\\\"]\\n15:[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"If you want the intended silhouette, buy your normal size. If you prefer a cleaner, more fitted oversized look, size down.\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"16:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"overflow-x-auto mt-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"table\\\",null,{\\\"className\\\":\\\"w-full text-[13px]\\\",\\\"aria-label\\\":\\\"Size guide measurements\\\",\\\"children\\\":[[\\\"$\\\",\\\"thead\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"tr\\\",null,{\\\"className\\\":\\\"border-b border-kvrn-border\\\",\\\"children\\\":[[\\\"$\\\",\\\"th\\\",null,{\\\"className\\\":\\\"text-left py-2 font-light label-11\\\",\\\"children\\\":\\\"Size\\\"}],[\\\"$\\\",\\\"th\\\",null,{\\\"className\\\":\\\"text-left py-2 font-light label-11\\\",\\\"children\\\":\\\"Chest (cm)\\\"}],[\\\"$\\\",\\\"th\\\",null,{\\\"className\\\":\\\"text-left py-2 font-light label-11\\\",\\\"children\\\":\\\"Length (cm)\\\"}],[\\\"$\\\",\\\"th\\\",null,{\\\"className\\\":\\\"text-left py-2 font-light label-11\\\",\\\"children\\\":\\\"Sleeve (cm)\\\"}]]}]}],[\\\"$\\\",\\\"tbody\\\",null,{\\\"className\\\":\\\"divide-y divide-kvrn-border\\\",\\\"children\\\":[[\\\"$\\\",\\\"tr\\\",\\\"XS\\\",{\\\"children\\\":[[\\\"$\\\",\\\"td\\\",null,{\\\"className\\\":\\\"py-2.5 font-light\\\",\\\"children\\\":\\\"XS\\\"}],[\\\"$\\\",\\\"td\\\",nul