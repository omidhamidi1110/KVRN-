{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/support/layout,_N_T_/support/faq/layout,_N_T_/support/faq/page,_N_T_/support/faq"}},"html":"<!DOCTYPE html><!--e_K6ZAIIOr_BCLYSvSh3P--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/d227774df0c1ffbf.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-74c939c87fa0092a.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-8210caca5b105758.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/909-aed3aa549e59d0fb.js\" async=\"\"></script><script src=\"/_next/static/chunks/356-1143d17a0ca27254.js\" async=\"\"></script><script src=\"/_next/static/chunks/799-3660c5de70670697.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-67a8d7c2dfb122bb.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/support/faq/page-fe7bd80131ff4fdc.js\" async=\"\"></script><meta name=\"theme-color\" content=\"#FAFAF8\"/><title>FAQ — KVRN | KVRN</title><meta name=\"description\" content=\"Frequently asked questions about KVRN products, sizing, shipping, and returns.\"/><meta name=\"author\" content=\"KVRN\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><meta name=\"keywords\" content=\"heavyweight hoodie,400 gsm hoodie,oversized hoodie,quiet luxury,premium hoodie,heavyweight fleece,structured hood,KVRN\"/><meta name=\"creator\" content=\"KVRN\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow\"/><meta property=\"og:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta property=\"og:description\" content=\"400 GSM+ heavyweight fleece. Structured 3-panel hood. Concealed interior zippers.\"/><meta property=\"og:url\" content=\"https://kvrn.com\"/><meta property=\"og:site_name\" content=\"KVRN\"/><meta property=\"og:locale\" content=\"en_GB\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"KVRN — Heavyweight Oversized Hoodies &amp; Sweatpants\"/><meta name=\"twitter:description\" content=\"400 GSM+ heavyweight fleece. Quiet luxury.\"/><link rel=\"icon\" href=\"/favicon.ico\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ClothingStore\",\"name\":\"KVRN\",\"url\":\"https://kvrn.com\",\"description\":\"Quiet luxury meets premium utility. Heavyweight oversized hoodies and sweatpants.\",\"sameAs\":[\"https://instagram.com/kvrn\",\"https://tiktok.com/@kvrn\"]}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-kvrn-bg text-kvrn-text font-body antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><a href=\"#main-content\" class=\"skip-link\">Skip to main content</a><script>\n          window.dataLayer=window.dataLayer||[];\n          function gtag(){dataLayer.push(arguments);}\n          gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',functionality_storage:'granted',wait_for_update:500});\n        </script><header class=\"fixed top-0 left-0 right-0 z-[200] h-[56px] flex items-center transition-all duration-300 bg-[var(--color-bg)] text-[var(--color-text)]\" aria-label=\"Site header\"><div class=\"kvrn-container w-full flex items-center justify-between\"><a class=\"text-[13px] font-light tracking-[0.2em] uppercase hover:opacity-60 transition-opacity duration-150\" aria-label=\"KVRN — go to homepage\" href=\"/\">KVRN</a><nav class=\"hidden md:flex items-center gap-10\" aria-label=\"Primary navigation\"><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/shop\">Shop</a><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/about\">About</a><a class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" href=\"/waitlist\">Waitlist</a></nav><div class=\"flex items-center gap-6\"><button class=\"text-[11px] font-light tracking-[0.14em] uppercase hover:opacity-60 transition-opacity duration-150\" aria-label=\"Shopping bag\">Bag</button><button class=\"md:hidden flex flex-col gap-[5px] p-1 -mr-1\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-nav\"><span class=\"block h-px w-[22px] transition-colors duration-300\" style=\"background-color:var(--color-text)\"></span><span class=\"block h-px w-[22px] transition-colors duration-300\" style=\"background-color:var(--color-text)\"></span></button></div></div></header><div class=\"fixed inset-0 z-[300] bg-black/40 transition-opacity duration-300 md:hidden opacity-0 pointer-events-none\" aria-hidden=\"true\"></div><div id=\"mobile-nav\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Navigation menu\" class=\"fixed inset-y-0 left-0 z-[400] w-[min(340px,100vw)] bg-[var(--color-bg)] flex flex-col px-6 pt-7 pb-10 overflow-y-auto transition-transform duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] md:hidden -translate-x-full\"><div class=\"flex items-center justify-between mb-10 flex-shrink-0\"><a class=\"text-[13px] font-light tracking-[0.2em] uppercase\" href=\"/\">KVRN</a><button class=\"p-2 -mr-2 text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\" aria-label=\"Close menu\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3L15 15M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><nav class=\"flex-1 space-y-8\" aria-label=\"Mobile navigation\"><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Shop</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/shop\">All Products</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Brand</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/about\">About KVRN</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></div></div><div><p class=\"kvrn-label text-[var(--color-muted)] mb-3\">Support</p><div class=\"space-y-1\"><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a><a class=\"block py-2.5 text-[15px] font-light text-[var(--color-text)] hover:text-[var(--color-muted)] transition-colors duration-150\" href=\"/contact\">Contact</a></div></div></nav><div class=\"mt-8 pt-6 border-t border-[var(--color-border)] flex gap-5 flex-shrink-0\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors\">Instagram</a></div></div><div class=\"fixed inset-0 z-[300] transition-all duration-300 bg-transparent pointer-events-none\" aria-hidden=\"true\"></div><div role=\"dialog\" aria-modal=\"true\" aria-label=\"Shopping bag\" class=\"fixed top-0 right-0 bottom-0 z-[400] w-full max-w-[400px] bg-[var(--color-bg)] flex flex-col transition-transform duration-[550ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] translate-x-full\"><div class=\"flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)]\"><h2 class=\"text-[11px] font-light tracking-[0.14em] uppercase\">Bag</h2><button aria-label=\"Close bag\" class=\"p-2 -mr-2 opacity-40 hover:opacity-100 transition-opacity\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 3l12 12M15 3L3 15\" stroke=\"currentColor\" stroke-width=\"1\" stroke-linecap=\"round\"></path></svg></button></div><div class=\"flex-1 overflow-y-auto scrollbar-thin\"><div class=\"flex flex-col items-center justify-center h-full px-6 text-center gap-5\"><p class=\"text-[14px] font-light text-[var(--color-muted)]\">Your bag is empty.</p><a href=\"/shop\"><button aria-busy=\"false\" class=\"relative inline-flex items-center justify-center font-body font-light tracking-widest uppercase transition-all duration-150 ease-out select-none whitespace-nowrap -webkit-tap-highlight-color: transparent bg-transparent text-kvrn-text border border-kvrn-text hover:bg-kvrn-text hover:text-kvrn-bg active:bg-[#333333] disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none h-10 px-5 text-[11px]\"><span class=\"flex items-center gap-2\">Browse collection</span></button></a></div></div></div><main id=\"main-content\"><div class=\"pt-[56px]\"><div class=\"container-kvrn section-padding max-w-3xl\"><nav aria-label=\"Breadcrumb\" class=\"mb-10\"><ol class=\"flex items-center gap-2 text-[11px] text-kvrn-muted tracking-wide\"><li><a class=\"hover:text-kvrn-text transition-colors\" href=\"/\">Home</a></li><li aria-hidden=\"true\">·</li><li class=\"text-kvrn-text\" aria-current=\"page\">FAQ</li></ol></nav><h1 class=\"font-display font-light text-[40px] md:text-[56px] leading-none tracking-tighter mb-16\">Questions</h1><div class=\"space-y-16\"><section aria-labelledby=\"section-Product\"><h2 id=\"section-Product\" class=\"label-11 mb-6\">Product</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-what-is-400-gsm\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What does 400 GSM mean?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-what-is-400-gsm\" role=\"region\" aria-labelledby=\"accordion-trigger-what-is-400-gsm\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-3\"><p>GSM stands for grams per square metre — the standard measurement of fabric weight. A higher number means a denser, heavier fabric.</p><p>Most hoodies on the market are 280–320 GSM. At 300 GSM, a hoodie feels light and somewhat provisional. At 400 GSM+, the fabric becomes structural — it holds its shape, drapes differently, and has a perceptible weight when you hold it.</p><p>KVRN is developed around heavyweight fleece construction. Full material specifications are listed on every product page.</p></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-why-no-drawstring\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">Why is there no drawstring?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-why-no-drawstring\" role=\"region\" aria-labelledby=\"accordion-trigger-why-no-drawstring\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>The 3-panel hood is engineered to hold its form without a drawstring. A drawstring is typically added because the hood collapses without it — the hood requires external support to maintain shape. KVRN&#x27;s hood structure eliminates that requirement. There is nothing to pull, nothing to lose, and nothing to interrupt the silhouette.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-hidden-zippers\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How do the hidden zippers work?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-hidden-zippers\" role=\"region\" aria-labelledby=\"accordion-trigger-hidden-zippers\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Each kangaroo pocket opening has a concealed YKK coil zipper running parallel behind it — one on each side. From the outside, with the zipper closed, the pockets appear completely standard. Open the zipper and you have access to a secure interior compartment. They are invisible in all positions.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-care\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How should I wash and care for the hoodie?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-care\" role=\"region\" aria-labelledby=\"accordion-trigger-care\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-3\"><p>Machine wash cold (30°C), inside out. Use a gentle cycle. Air dry — do not tumble dry. Do not iron the rubber patch.</p><p>The fleece will soften over the first 3–5 washes. This is expected behaviour — the fabric continues to improve with regular wear and care. The structure of the hood and the integrity of the zippers are not affected by washing.</p></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-fabric\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What is the fabric composition?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-fabric\" role=\"region\" aria-labelledby=\"accordion-trigger-fabric\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>100% ring-spun combed cotton. No polyester blend. Ring-spun cotton is stronger and softer than standard spun cotton due to the way the fibres are twisted. Combing removes short fibres and impurities, resulting in a cleaner, more durable yarn.</p></div></div></div></div></section><section id=\"sizing\" aria-labelledby=\"section-Sizing\"><h2 id=\"section-Sizing\" class=\"label-11 mb-6\">Sizing</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-sizing-guide\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How does KVRN fit?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-sizing-guide\" role=\"region\" aria-labelledby=\"accordion-trigger-sizing-guide\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><div class=\"space-y-4\"><p>KVRN is designed to be oversized. This is not a standard fit with extra room — it is a considered oversized silhouette where the proportions are deliberate.</p><p>If you want the intended silhouette, buy your normal size. If you prefer a cleaner, more fitted oversized look, size down.</p><div class=\"overflow-x-auto mt-4\"><table class=\"w-full text-[13px]\" aria-label=\"Size guide measurements\"><thead><tr class=\"border-b border-kvrn-border\"><th class=\"text-left py-2 font-light label-11\">Size</th><th class=\"text-left py-2 font-light label-11\">Chest (cm)</th><th class=\"text-left py-2 font-light label-11\">Length (cm)</th><th class=\"text-left py-2 font-light label-11\">Sleeve (cm)</th></tr></thead><tbody class=\"divide-y divide-kvrn-border\"><tr><td class=\"py-2.5 font-light\">XS</td><td class=\"py-2.5 text-kvrn-muted\">60</td><td class=\"py-2.5 text-kvrn-muted\">72</td><td class=\"py-2.5 text-kvrn-muted\">63</td></tr><tr><td class=\"py-2.5 font-light\">S</td><td class=\"py-2.5 text-kvrn-muted\">64</td><td class=\"py-2.5 text-kvrn-muted\">74</td><td class=\"py-2.5 text-kvrn-muted\">64</td></tr><tr><td class=\"py-2.5 font-light\">M</td><td class=\"py-2.5 text-kvrn-muted\">68</td><td class=\"py-2.5 text-kvrn-muted\">76</td><td class=\"py-2.5 text-kvrn-muted\">65</td></tr><tr><td class=\"py-2.5 font-light\">L</td><td class=\"py-2.5 text-kvrn-muted\">72</td><td class=\"py-2.5 text-kvrn-muted\">78</td><td class=\"py-2.5 text-kvrn-muted\">66</td></tr><tr><td class=\"py-2.5 font-light\">XL</td><td class=\"py-2.5 text-kvrn-muted\">76</td><td class=\"py-2.5 text-kvrn-muted\">80</td><td class=\"py-2.5 text-kvrn-muted\">67</td></tr><tr><td class=\"py-2.5 font-light\">XXL</td><td class=\"py-2.5 text-kvrn-muted\">80</td><td class=\"py-2.5 text-kvrn-muted\">82</td><td class=\"py-2.5 text-kvrn-muted\">68</td></tr></tbody></table><p class=\"text-[12px] text-kvrn-muted mt-3\">All measurements in centimetres, taken flat. ±1.5cm tolerance.</p></div></div></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-between-sizes\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">I am between sizes — what should I do?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-between-sizes\" role=\"region\" aria-labelledby=\"accordion-trigger-between-sizes\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Size down for a cleaner oversized silhouette. The oversized cut means even a smaller size will have substantial volume. If you are unsure, email us at hello@kvrn.com with your height and usual size — we will give you a specific recommendation.</p></div></div></div></div></section><section aria-labelledby=\"section-Orders &amp; Shipping\"><h2 id=\"section-Orders &amp; Shipping\" class=\"label-11 mb-6\">Orders &amp; Shipping</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-order-time\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">When will my order ship?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-order-time\" role=\"region\" aria-labelledby=\"accordion-trigger-order-time\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Orders are typically processed within 1–2 business days. You will receive a tracking number by email once your order has shipped.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-international-duties\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">Will I pay import duties on international orders?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-international-duties\" role=\"region\" aria-labelledby=\"accordion-trigger-international-duties\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Orders shipped outside the UK may be subject to import duties and taxes levied by the destination country&#x27;s customs authority. These charges are the responsibility of the recipient and are not included in the shipping cost. For EU orders, we ship DDU (Delivered Duty Unpaid) — you will be contacted by your local customs authority if duties apply.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-order-tracking\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">How do I track my order?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-order-tracking\" role=\"region\" aria-labelledby=\"accordion-trigger-order-tracking\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Once your order ships, you will receive an email with your tracking number and a direct link to track your parcel. If you have not received a shipping confirmation within 2 business days of ordering, check your spam folder or contact us at hello@kvrn.com.</p></div></div></div></div></section><section aria-labelledby=\"section-Returns\"><h2 id=\"section-Returns\" class=\"label-11 mb-6\">Returns</h2><div class=\"divide-y divide-kvrn-border border-t border-kvrn-border\"><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-returns-window\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What is the return window?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-returns-window\" role=\"region\" aria-labelledby=\"accordion-trigger-returns-window\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>30 days from the date of delivery, on unworn, unwashed items with tags attached. To initiate a return, email hello@kvrn.com with your order number.</p></div></div></div><div><button type=\"button\" aria-expanded=\"false\" aria-controls=\"accordion-faulty\" class=\"w-full flex items-center justify-between py-4 text-[13px] font-body font-light tracking-widest uppercase text-left hover:text-kvrn-muted transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-kvrn-text\">What if my item is faulty?<span aria-hidden=\"true\" class=\"ml-4 flex-shrink-0 w-4 h-4 relative\"><span class=\"absolute top-1/2 left-0 right-0 h-px bg-current -translate-y-1/2\"></span><span class=\"absolute top-0 bottom-0 left-1/2 w-px bg-current -translate-x-1/2 transition-transform duration-300\"></span></span></button><div id=\"accordion-faulty\" role=\"region\" aria-labelledby=\"accordion-trigger-faulty\" class=\"overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0\"><div class=\"pb-6 text-[14px] text-kvrn-muted leading-relaxed\"><p>Faulty items are covered under your statutory consumer rights regardless of the 30-day window. Contact us immediately with photos of the fault at hello@kvrn.com. We will arrange a replacement or full refund — whichever you prefer.</p></div></div></div></div></section></div><div class=\"mt-20 pt-10 border-t border-kvrn-border\"><p class=\"text-[15px] font-light mb-2\">Still have a question?</p><p class=\"text-[14px] text-kvrn-muted mb-4\">Email us at<!-- --> <a href=\"mailto:hello@kvrn.com\" class=\"text-kvrn-text underline underline-offset-2 hover:opacity-70 transition-opacity\">hello@kvrn.com</a>. We respond within 24 hours.</p><a class=\"text-[13px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150 underline underline-offset-2\" href=\"/contact\">Send a message →</a></div></div></div><!--$--><!--/$--></main><footer class=\"border-t border-[var(--color-border)] bg-[var(--color-bg)]\" aria-label=\"Site footer\"><div class=\"kvrn-container\"><div class=\"py-16 md:py-24 grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 md:gap-16\"><div class=\"col-span-2 md:col-span-1\"><a class=\"block text-[14px] font-light tracking-[0.2em] uppercase mb-5\" href=\"/\">KVRN</a><p class=\"text-[13px] text-[var(--color-muted)] leading-relaxed max-w-[200px]\">Designed slowly.<br/>Built to remain.</p><div class=\"flex gap-5 mt-6\"><a href=\"https://instagram.com/kvrn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[11px] tracking-[0.14em] uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" aria-label=\"KVRN on Instagram\">Instagram</a></div></div><div><p class=\"kvrn-label mb-5\">Shop</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/shop\">All Products</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-hoodie\">Heavyweight Hoodie</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/products/kvrn-heavyweight-sweatpants\">Heavyweight Sweatpants</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/waitlist\">Waitlist</a></li></ul></div><div><p class=\"kvrn-label mb-5\">Brand</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/about\">About</a></li></ul></div><div><p class=\"kvrn-label mb-5\">Support</p><ul class=\"space-y-3\"><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/faq\">FAQ</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/track\">Track order</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/shipping-returns\">Shipping &amp; Returns</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/support/size-guide\">Size Guide</a></li><li><a class=\"text-[13px] font-light text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150\" href=\"/contact\">Contact</a></li></ul></div></div><div class=\"py-6 border-t border-[var(--color-border)] flex flex-col md:flex-row items-start md:items-center justify-between gap-4\"><p class=\"text-[11px] text-[var(--color-muted)] tracking-wide\">© <!-- -->2026<!-- --> KVRN. All rights reserved.</p><div class=\"flex flex-wrap gap-x-5 gap-y-2\"><a class=\"text-[11px] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150 tracking-wide\" href=\"/privacy\">Privacy</a><a class=\"text-[11px] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150 tracking-wide\"