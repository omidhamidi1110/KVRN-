n\":[\"© \",2026,\" KVRN. All rights reserved.\"]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-x-5 gap-y-2\",\"children\":[[\"$\",\"$L8\",\"/privacy\",{\"href\":\"/privacy\",\"className\":\"text-[11px] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150 tracking-wide\",\"children\":\"Privacy\"}],[\"$\",\"$L8\",\"/terms\",{\"href\":\"/terms\",\"className\":\"text-[11px] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150 tracking-wide\",\"children\":\"Terms\"}],[\"$\",\"$L8\",\"/cookies\",{\"href\":\"/cookies\",\"className\":\"text-[11px] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-150 tracking-wide\",\"children\":\"Cookies\"}]]}]]}]\nf:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L6\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L7\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n10:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L6\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L7\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n11:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"pt-[56px]\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-kvrn section-padding max-w-3xl\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"mb-10\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-2 text-[11px] text-kvrn-muted tracking-wide\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L8\",null,{\"href\":\"/\",\"className\":\"hover:text-kvrn-text transition-colors\",\"children\":\"Home\"}]}],[\"$\",\"li\",null,{\"aria-hidden\":\"true\",\"children\":\"·\"}],[\"$\",\"li\",null,{\"className\":\"text-kvrn-text\",\"aria-current\":\"page\",\"children\":\"FAQ\"}]]}]}],[\"$\",\"h1\",null,{\"className\":\"font-display font-light text-[40px] md:text-[56px] leading-none tracking-tighter mb-16\",\"children\":\"Questions\"}],[\"$\",\"div\",null,{\"className\":\"space-y-16\",\"children\":[[\"$\",\"section\",\"Product\",{\"id\":\"$undefined\",\"aria-labelledby\":\"section-Product\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Product\",\"className\":\"label-11 mb-6\",\"children\":\"Product\"}],[\"$\",\"$L14\",null,{\"items\":[{\"id\":\"what-is-400-gsm\",\"trigger\":\"What does 400 GSM mean?\",\"content\":[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"GSM stands for grams per square metre — the standard measurement of fabric weight. A higher number means a denser, heavier fabric.\"}],[\"$\",\"p\",null,{\"children\":\"Most hoodies on the market are 280–320 GSM. At 300 GSM, a hoodie feels light and somewhat provisional. At 400 GSM+, the fabric becomes structural — it holds its shape, drapes differently, and has a perceptible weight when you hold it.\"}],[\"$\",\"p\",null,{\"children\":\"KVRN is developed around heavyweight fleece construction. Full material specifications are listed on every product page.\"}]]}]},{\"id\":\"why-no-drawstring\",\"trigger\":\"Why is there no drawstring?\",\"content\":[\"$\",\"p\",null,{\"children\":\"The 3-panel hood is engineered to hold its form without a drawstring. A drawstring is typically added because the hood collapses without it — the hood requires external support to maintain shape. KVRN's hood structure eliminates that requirement. There is nothing to pull, nothing to lose, and nothing to interrupt the silhouette.\"}]},{\"id\":\"hidden-zippers\",\"trigger\":\"How do the hidden zippers work?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Each kangaroo pocket opening has a concealed YKK coil zipper running parallel behind it — one on each side. From the outside, with the zipper closed, the pockets appear completely standard. Open the zipper and you have access to a secure interior compartment. They are invisible in all positions.\"}]},{\"id\":\"care\",\"trigger\":\"How should I wash and care for the hoodie?\",\"content\":[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Machine wash cold (30°C), inside out. Use a gentle cycle. Air dry — do not tumble dry. Do not iron the rubber patch.\"}],[\"$\",\"p\",null,{\"children\":\"The fleece will soften over the first 3–5 washes. This is expected behaviour — the fabric continues to improve with regular wear and care. The structure of the hood and the integrity of the zippers are not affected by washing.\"}]]}]},{\"id\":\"fabric\",\"trigger\":\"What is the fabric composition?\",\"content\":[\"$\",\"p\",null,{\"children\":\"100% ring-spun combed cotton. No polyester blend. Ring-spun cotton is stronger and softer than standard spun cotton due to the way the fibres are twisted. Combing removes short fibres and impurities, resulting in a cleaner, more durable yarn.\"}]}]}]]}],[\"$\",\"section\",\"Sizing\",{\"id\":\"sizing\",\"aria-labelledby\":\"section-Sizing\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Sizing\",\"className\":\"label-11 mb-6\",\"children\":\"Sizing\"}],[\"$\",\"$L14\",null,{\"items\":[{\"id\":\"sizing-guide\",\"trigger\":\"How does KVRN fit?\",\"content\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":\"KVRN is designed to be oversized. This is not a standard fit with extra room — it is a considered oversized silhouette where the proportions are deliberate.\"}],\"$L15\",\"$L16\"]}]},{\"id\":\"between-sizes\",\"trigger\":\"I am between sizes — what should I do?\",\"content\":\"$L17\"}]}]]}],\"$L18\",\"$L19\"]}],\"$L1a\"]}]}],null,\"$L1b\"]}]\n12:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L1c\",null,{\"children\":\"$L1d\"}],null],[\"$\",\"$L1e\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$1f\",null,{\"fallback\":null,\"children\":\"$L20\"}]}]}]]}]\n21:I[4431,[],\"OutletBoundary\"]\n23:I[5278,[],\"AsyncMetadataOutlet\"]\n15:[\"$\",\"p\",null,{\"children\":\"If you want the intended silhouette, buy your normal size. If you prefer a cleaner, more fitted oversized look, size down.\"}]\n16:[\"$\",\"div\",null,{\"className\":\"overflow-x-auto mt-4\",\"children\":[[\"$\",\"table\",null,{\"className\":\"w-full text-[13px]\",\"aria-label\":\"Size guide measurements\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"className\":\"border-b border-kvrn-border\",\"children\":[[\"$\",\"th\",null,{\"className\":\"text-left py-2 font-light label-11\",\"children\":\"Size\"}],[\"$\",\"th\",null,{\"className\":\"text-left py-2 font-light label-11\",\"children\":\"Chest (cm)\"}],[\"$\",\"th\",null,{\"className\":\"text-left py-2 font-light label-11\",\"children\":\"Length (cm)\"}],[\"$\",\"th\",null,{\"className\":\"text-left py-2 font-light label-11\",\"children\":\"Sleeve (cm)\"}]]}]}],[\"$\",\"tbody\",null,{\"className\":\"divide-y divide-kvrn-border\",\"children\":[[\"$\",\"tr\",\"XS\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"XS\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":60}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":72}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":63}]]}],[\"$\",\"tr\",\"S\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"S\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":64}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":74}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":64}]]}],[\"$\",\"tr\",\"M\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"M\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":68}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":76}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":65}]]}],[\"$\",\"tr\",\"L\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"L\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":72}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":78}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":66}]]}],[\"$\",\"tr\",\"XL\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"XL\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":76}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":80}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":67}]]}],[\"$\",\"tr\",\"XXL\",{\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2.5 font-light\",\"children\":\"XXL\"}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":80}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":82}],[\"$\",\"td\",null,{\"className\":\"py-2.5 text-kvrn-muted\",\"children\":68}]]}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-[12px] text-kvrn-muted mt-3\",\"children\":\"All measurements in centimetres, taken flat. ±1.5cm tolerance.\"}]]}]\n17:[\"$\",\"p\",null,{\"children\":\"Size down for a cleaner oversized silhouette. The oversized cut means even a smaller size will have substantial volume. If you are unsure, email us at hello@kvrn.com with your height and usual size — we will give you a specific recommendation.\"}]\n18:[\"$\",\"section\",\"Orders & Shipping\",{\"id\":\"$undefined\",\"aria-labelledby\":\"section-Orders & Shipping\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Orders & Shipping\",\"className\":\"label-11 mb-6\",\"children\":\"Orders & Shipping\"}],[\"$\",\"$L14\",null,{\"items\":[{\"id\":\"order-time\",\"trigger\":\"When will my order ship?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Orders are typically processed within 1–2 business days. You will receive a tracking number by email once your order has shipped.\"}]},{\"id\":\"international-duties\",\"trigger\":\"Will I pay import duties on international orders?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Orders shipped outside the UK may be subject to import duties and taxes levied by the destination country's customs authority. These charges are the responsibility of the recipient and are not included in the shipping cost. For EU orders, we ship DDU (Delivered Duty Unpaid) — you will be contacted by your local customs authority if duties apply.\"}]},{\"id\":\"order-tracking\",\"trigger\":\"How do I track my order?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Once your order ships, you will receive an email with your tracking number and a direct link to track your parcel. If you have not received a shipping confirmation within 2 business days of ordering, check your spam folder or contact us at hello@kvrn.com.\"}]}]}]]}]\n19:[\"$\",\"section\",\"Returns\",{\"id\":\"$undefined\",\"aria-labelledby\":\"section-Returns\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"section-Returns\",\"className\":\"label-11 mb-6\",\"children\":\"Returns\"}],[\"$\",\"$L14\",null,{\"items\":[{\"id\":\"returns-window\",\"trigger\":\"What is the return window?\",\"content\":[\"$\",\"p\",null,{\"children\":\"30 days from the date of delivery, on unworn, unwashed items with tags attached. To initiate a return, email hello@kvrn.com with your order number.\"}]},{\"id\":\"faulty\",\"trigger\":\"What if my item is faulty?\",\"content\":[\"$\",\"p\",null,{\"children\":\"Faulty items are covered under your statutory consumer rights regardless of the 30-day window. Contact us immediately with photos of the fault at hello@kvrn.com. We will arrange a replacement or full refund — whichever you prefer.\"}]}]}]]}]\n1a:[\"$\",\"div\",null,{\"className\":\"mt-20 pt-10 border-t border-kvrn-border\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[15px] font-light mb-2\",\"children\":\"Still have a question?\"}],[\"$\",\"p\",null,{\"className\":\"text-[14px] text-kvrn-muted mb-4\",\"children\":[\"Email us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@kvrn.com\",\"className\":\"text-kvrn-text underline underline-offset-2 hover:opacity-70 transition-opacity\",\"children\":\"hello@kvrn.com\"}],\". We respond within 24 hours.\"]}],[\"$\",\"$L8\",null,{\"href\":\"/contact\",\"className\":\"text-[13px] text-kvrn-muted hover:text-kvrn-text transition-colors duration-150 underline underline-offset-2\",\"children\":\"Send a message →\"}]]}]\n1b:[\"$\",\"$L21\",null,{\"children\":[\"$L22\",[\"$\",\"$L23\",null,{\"promise\":\"$@24\"}]]}]\n1d:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#FAFAF8\"}]]\n22:null\n25:I[622,[],\"IconMark\"]\n24:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"FAQ — KVRN | KVRN\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Frequently asked questions about KVRN products, sizing, shipping, and returns.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"author\",\"content\":\"KVRN\"}],[\"$\",\"link\",\"3\",{\"rel\":\"manifest\",\"href\":\"/site.webmanifest\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"heavyweight hoodie,400 gsm hoodie,oversized hoodie,quiet luxury,premium hoodie,heavyweight fleece,structured hood,KVRN\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"KVRN\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"cont