ull,{\"children\":\"These terms govern your use of kvrn.com and any purchase you make from KVRN, operated by [KVRN Ltd], registered in England and Wales (Company No. [XXXXXXXX]). By placing an order, you agree to these terms.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rule\"}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[15px] font-light text-kvrn-text mb-3\",\"children\":\"Orders and contract formation\"}],[\"$\",\"p\",null,{\"className\":\"mb-3\",\"children\":\"Placing an order is an offer to buy. A contract between you and KVRN is formed when we confirm your order by email — not at the point of placing it.\"}],[\"$\",\"p\",null,{\"children\":\"We reserve the right to cancel any order before dispatch. If we cancel your order, we will refund you in full within 5 business days. We will notify you by email.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rule\"}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[15px] font-light text-kvrn-text mb-3\",\"children\":\"Pricing and payment\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"All prices are displayed in GBP and include UK VAT at 20%.\"}],[\"$\",\"li\",null,{\"children\":\"International orders may be subject to import duties and taxes payable by you.\"}],[\"$\",\"li\",null,{\"children\":\"We accept payment via Stripe (card, Apple Pay, Google Pay).\"}],[\"$\",\"li\",null,{\"children\":\"Payment is taken immediately on order confirmation.\"}],[\"$\",\"li\",null,{\"children\":\"If a pricing error occurs, we will notify you and give you the option to reorder at the correct price or cancel.\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"rule\"}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[15px] font-light text-kvrn-text mb-3\",\"children\":\"Delivery\"}],[\"$\",\"p\",null,{\"className\":\"mb-3\",\"children\":\"Delivery timescales are estimates and not guaranteed. We are not liable for delays caused by customs, weather, carrier issues, or events outside our control.\"}],[\"$\",\"p\",null,{\"children\":\"Risk of loss passes to you when the carrier accepts the parcel. If your order is lost in transit, contact us and we will investigate with the carrier.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rule\"}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[15px] font-light text-kvrn-text mb-3\",\"children\":\"Returns and consumer rights\"}],[\"$\",\"p\",null,{\"className\":\"mb-3\",\"children\":\"You have the right to cancel your order within 14 days of delivery under the Consumer Contracts Regulations 2013. Our 30-day returns window exceeds this statutory minimum.\"}],[\"$\",\"p\",null,{\"children\":[\"Faulty goods are covered under the Consumer Rights Act 2015 regardless of our returns window. Contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@kvrn.com\",\"className\":\"text-kvrn-text underline underline-offset-2\",\"children\":\"hello@kvrn.com\"}],\" \",\"for all warranty and fault claims.\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":[\"See our full\",\" \",\"$L13\",\".\"]}]]}],\"$L14\",\"$L15\",\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$L1b\"]}]]}]}],null,\"$L1c\"]}]\n11:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L1d\",null,{\"children\":\"$L1e\"}],null],[\"$\",\"$L1f\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$20\",null,{\"fallback\":null,\"children\":\"$L21\"}]}]}]]}]\n22:I[4431,[],\"OutletBoundary\"]\n24:I[5278,[],\"AsyncMetadataOutlet\"]\n13:[\"$\",\"$L8\",null,{\"href\":\"/support/shipping-returns\",\"className\":\"text-kvrn-text underline underline-offset-2\",\"children\":\"Shipping & Returns policy\"}]\n14:[\"$\",\"div\",null,{\"className\":\"rule\"}]\n15:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-[15px] font-light text-kvrn-text mb-3\",\"children\":\"Intellectual property\"}]